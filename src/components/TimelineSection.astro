---
interface Actividad {
  hora: string;
  actividad: string;
}

interface Props {
  actividades?: Actividad[];
}

const { actividades = [] } = Astro.props;
---

<div class="timeline-section">
  <div class="timeline-header">
    <h3>Agenda del Evento</h3>
    <button type="button" id="addActivity" class="add-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <line x1="5" y1="12" x2="19" y2="12"></line>
      </svg>
      Agregar actividad
    </button>
  </div>

  <div id="timelineContainer" class="timeline-container">
    {actividades.length === 0 ? (
      <p class="empty-message">No hay actividades programadas</p>
    ) : (
      actividades.map((item, index) => (
        <div class="timeline-item" data-index={index}>
          <div class="timeline-time">
            <input 
              type="time" 
              name={`actividades[${index}][hora]`}
              value={item.hora}
              required
            />
          </div>
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <input 
              type="text" 
              name={`actividades[${index}][actividad]`}
              value={item.actividad}
              placeholder="Descripción de la actividad"
              required
            />
            <button type="button" class="remove-activity" title="Eliminar">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
        </div>
      ))
    )}
  </div>
</div>

<style>
  .timeline-section {
    margin-top: 2rem;
    padding: 1.5rem;
    border: 2px solid var(--spotify-gray);
    border-radius: 12px;
    background-color: rgba(18, 18, 18, 0.5);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .timeline-header h3 {
    color: var(--spotify-green);
    margin: 0;
    font-size: 1.2rem;
  }

  .add-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background-color: transparent;
    border: 2px solid var(--spotify-green);
    color: var(--spotify-green);
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.2s;
  }

  .add-btn:hover {
    background-color: var(--spotify-green);
    color: black;
  }

  .timeline-container {
    display: flex;
    flex-direction: column;
  }

  .empty-message {
    color: var(--spotify-gray);
    text-align: center;
    padding: 1rem;
    font-style: italic;
  }

  .timeline-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    position: relative;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: 75px;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: var(--spotify-green);
  }

  .timeline-item:last-child::before {
    display: none;
  }

  .timeline-time input {
    width: 100px;
    padding: 0.5rem;
    border: 2px solid var(--spotify-green);
    border-radius: 8px;
    background-color: var(--spotify-dark);
    color: white;
    font-size: 0.9rem;
  }

  .timeline-time input::-webkit-calendar-picker-indicator {
    filter: invert(1);
  }

  .timeline-marker {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--spotify-green);
    border: 2px solid var(--spotify-dark);
    z-index: 1;
    flex-shrink: 0;
  }

  .timeline-content {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .timeline-content input {
    flex: 1;
    padding: 0.5rem;
    border: 2px solid var(--spotify-gray);
    border-radius: 8px;
    background-color: var(--spotify-dark);
    color: white;
    font-size: 0.9rem;
  }

  .timeline-content input:focus {
    outline: none;
    border-color: var(--spotify-green);
  }

  .remove-activity {
    padding: 0.5rem;
    background: transparent;
    border: none;
    color: var(--spotify-gray);
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.2s;
  }

  .remove-activity:hover {
    background-color: rgba(255, 0, 0, 0.2);
    color: #ff4444;
  }
</style>

<script>
  let activityIndex = document.querySelectorAll('.timeline-item').length;

  document.getElementById('addActivity')?.addEventListener('click', () => {
    const container = document.getElementById('timelineContainer');
    const emptyMessage = container?.querySelector('.empty-message');
    if (emptyMessage) emptyMessage.remove();

    const item = document.createElement('div');
    item.className = 'timeline-item';
    item.dataset.index = String(activityIndex);
    item.innerHTML = `
      <div class="timeline-time">
        <input type="time" name="actividades[${activityIndex}][hora]" required />
      </div>
      <div class="timeline-marker"></div>
      <div class="timeline-content">
        <input type="text" name="actividades[${activityIndex}][actividad]" placeholder="Descripción de la actividad" required />
        <button type="button" class="remove-activity" title="Eliminar">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    `;

    item.querySelector('.remove-activity')?.addEventListener('click', () => {
      item.remove();
    });

    container?.appendChild(item);
    activityIndex++;
  });

  document.querySelectorAll('.remove-activity').forEach(button => {
    button.addEventListener('click', (e) => {
      const item = (e.currentTarget as HTMLElement).closest('.timeline-item');
      item?.remove();
    });
  });
</script>
