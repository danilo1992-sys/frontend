---
import Auth from '../layouts/AuthLayout.astro'
---
<Auth>
  <div class="flex items-center justify-center min-h-screen">
    <div class="p-8 rounded-lg border-2" style="background-color: var(--spotify-black); border-color: var(--spotify-green);">
      <h1 class="text-2xl font-bold mb-6 text-center" style="color: var(--spotify-green)">Iniciar Sesión</h1>
      <div class="flex flex-col gap-4">
        <a 
          href="/api/auth/signin/google"
          class="px-6 py-3 rounded-lg font-medium text-center transition-colors"
          style="background-color: var(--spotify-green); color: black;"
        >
          Continuar con Google
        </a>
      </div>
    </div>
  </div>
</Auth>