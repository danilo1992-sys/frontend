---
import AuthLayouts from "../layouts/AuthLayout.astro";
import { Show, SignInButton, SignUpButton, UserButton } from "@clerk/astro/components";
---

<AuthLayouts>
    <Show when="signed-out">
        <div class="flex flex-col items-center justify-center min-h-screen gap-6">
            <div class="text-center">
                <h1 class="text-4xl font-bold mb-2" style="color: var(--spotify-green)">Bienvenido</h1>
                <p class="text-lg" style="color: var(--spotify-gray)">Inicia sesión para continuar</p>
            </div>
            <div class="flex flex-col gap-3 w-64">
                <SignInButton mode="modal" />
                <SignUpButton mode="modal" />
            </div>
        </div>
    </Show>

    <Show when="signed-in">
        <div class="flex flex-col items-center justify-center min-h-screen gap-6">
            <p style="color: var(--spotify-gray)">Ya tienes una sesión activa</p>
            <UserButton />
        </div>
    </Show>
</AuthLayouts>
